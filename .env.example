# Copy this to .env and fill in the values
# Never commit .env to version control

# ============================================================================
# Node Environment
# ============================================================================
NODE_ENV=development

# ============================================================================
# API Server
# ============================================================================
API_PORT=3000
API_HOST=0.0.0.0

# ============================================================================
# Database (PostgreSQL 16)
# Run infra with: npm run infra:up
# ============================================================================
DATABASE_URL=postgresql://imagiverse_user:imagiverse_password@localhost:5432/imagiverse

# ============================================================================
# Cache / Queue (Redis 7)
# ============================================================================
REDIS_URL=redis://localhost:6379

# ============================================================================
# Object Storage (Garage v2 — S3-compatible)
# Run infra with: npm run infra:up
# Then run: docker compose -f docker/docker-compose.yml run --rm garage-init
# The init script will print real S3_ACCESS_KEY and S3_SECRET_KEY — paste them below.
# Garage v2 generates keys in GKxxxx format; placeholders won't work.
# ============================================================================
S3_ENDPOINT=http://localhost:3900
S3_PUBLIC_ENDPOINT=
S3_BUCKET=imagiverse-media
S3_ACCESS_KEY=REPLACE_WITH_GARAGE_GENERATED_KEY
S3_SECRET_KEY=REPLACE_WITH_GARAGE_GENERATED_SECRET
S3_REGION=us-east-1
S3_USE_SSL=false

# ============================================================================
# Authentication (JWT)
# IMPORTANT: Use long random strings in production (min 32 chars)
# Generate with: openssl rand -hex 32
# ============================================================================
JWT_SECRET=dev-jwt-secret-change-in-production-must-be-at-least-32-chars
JWT_REFRESH_SECRET=dev-refresh-secret-change-in-production-must-be-at-least-32
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ============================================================================
# Worker (BullMQ)
# ============================================================================
WORKER_PORT=3001
WORKER_CONCURRENCY=3

# ============================================================================
# Garage Admin (used by setup scripts only)
# ============================================================================
GARAGE_ADMIN_TOKEN=dev-admin-token-change-in-production
GARAGE_ADMIN_URL=http://localhost:3902
