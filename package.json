{
  "name": "imagiverse",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.1",
  "workspaces": [
    "client",
    "server",
    "shared"
  ],
  "scripts": {
    "dev:api": "pnpm --filter imagiverse-server dev",
    "dev:worker": "pnpm --filter imagiverse-server dev:worker",
    "build": "pnpm --filter imagiverse-shared run build && pnpm --filter imagiverse-server run build",
    "build:client": "pnpm --filter client build",
    "lint": "biome check .",
    "lint:fix": "biome check --write .",
    "format": "biome format --write .",
    "type-check": "tsc --noEmit -p tsconfig.json && tsc --noEmit -p tsconfig.server.json",
    "test": "pnpm --filter imagiverse-server test",
    "infra:up": "docker compose -f docker/docker-compose.yml up -d postgres redis garage",
    "infra:down": "docker compose -f docker/docker-compose.yml down"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "sharp",
      "msgpackr-extract"
    ]
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.4",
    "typescript": "^5.9.3"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
